{
  "name": "@alucpro/tool-manage",
  "version": "0.1.5",
  "description": "Register, inspect, enrich, and manage local CLI commands with sqlite-backed metadata.",
  "type": "module",
  "private": false,
  "bin": {
    "tm": "./src/cli.js"
  },
  "files": [
    "src",
    "templates"
  ],
  "license": "MIT",
  "author": "Xuming <jinxm.alucard@gmail.com>",
  "homepage": "https://github.com/AlucPro/tool-manage#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlucPro/tool-manage.git"
  },
  "bugs": {
    "url": "https://github.com/AlucPro/tool-manage/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "start": "node ./src/cli.js",
    "dev": "node ./src/cli.js --help",
    "check": "node ./src/cli.js --help",
    "list": "node ./src/cli.js --list",
    "show": "node ./src/cli.js --show pnpm"
  },
  "keywords": [
    "cli",
    "npm",
    "tool",
    "tm",
    "command-registry",
    "sqlite"
  ],
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "cli-table3": "^0.6.5",
    "sql.js": "^1.14.1"
  }
}