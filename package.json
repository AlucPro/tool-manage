{
  "name": "@alucpro/tool-manage",
  "version": "0.2.3",
  "description": "A sqlite-backed local registry for managing CLI tools, scripts, and internal commands.",
  "type": "module",
  "private": false,
  "bin": {
    "tm": "src/cli.js"
  },
  "files": [
    "src",
    "templates",
    "schema"
  ],
  "license": "MIT",
  "author": "Xuming <jinxm.alucard@gmail.com>",
  "homepage": "https://github.com/AlucPro/tool-manage#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlucPro/tool-manage.git"
  },
  "bugs": {
    "url": "https://github.com/AlucPro/tool-manage/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "start": "node ./src/cli.js",
    "dev": "node ./src/cli.js --help",
    "check": "node ./src/cli.js --help",
    "test": "node --test",
    "list": "node ./src/cli.js --list",
    "show": "node ./src/cli.js --show pnpm"
  },
  "keywords": [
    "cli",
    "command-line",
    "terminal",
    "developer-tools",
    "tool-manager",
    "command-registry",
    "script-manager",
    "local-first",
    "productivity",
    "sqlite",
    "ai-coding",
    "npm",
    "pnpm"
  ],
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "cli-table3": "^0.6.5",
    "sql.js": "^1.14.1"
  }
}
